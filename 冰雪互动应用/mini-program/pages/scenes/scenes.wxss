/* pages/scenes/scenes.wxss */
.scenes-container {
  background: linear-gradient(to bottom, #1e3c72 0%, #2a5298 100%);
  min-height: 100vh;
  position: relative;
}

.page-header {
  padding: 80rpx 40rpx 40rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.scenes-list {
  padding: 0 40rpx 40rpx;
}

.scene-card {
  position: relative;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  transition: all 0.3s;
  border: 1px solid rgba(255, 255, 255, 0.2);
  position: relative;
}

.scene-card:active {
  transform: scale(0.98);
}

.scene-card::before {
  content: '📸';
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 36rpx;
  color: #FFD700;
  opacity: 0;
  transition: opacity 0.3s;
}

.scene-card.favorite::before {
  opacity: 1;
}

.scene-image {
  position: relative;
  height: 300rpx;
  overflow: hidden;

  image {
    width: 100%;
    height: 100%;
    transition: transform 0.3s;
  }

  .scene-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30rpx;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 100%);
  }

  .scene-info {
    color: white;

    .scene-name {
      display: block;
      font-size: 36rpx;
      font-weight: bold;
      margin-bottom: 10rpx;
    }

    .scene-location {
      display: block;
      font-size: 24rpx;
      opacity: 0.8;
    }
  }
}

.scene-image:hover image {
  transform: scale(1.02);
}

.scene-details {
  padding: 30rpx;

  .scene-desc {
    display: block;
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin-bottom: 20rpx;
  }

  .scene-stats {
    display: flex;
    gap: 30rpx;
    font-size: 24rpx;
    color: rgba(255, 255, 255, 0.6);
  }
}

.visited-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: #10B981;
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  animation: pulse 2s infinite;

  .van-icon {
    font-size: 20rpx;
  }
}

.favorite-badge {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  background: rgba(255, 215, 0, 0.8);
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  animation: pulse 2s infinite;
}

/* 全景查看器 */
.panorama-viewer {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.viewer-header {
  padding: 30rpx;
  background: rgba(0, 0, 0, 0.3);
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);

  .scene-info {
    .scene-name {
      display: block;
      font-size: 36rpx;
      font-weight: bold;
      margin-bottom: 10rpx;
    }

    .scene-location {
      font-size: 24rpx;
      opacity: 0.8;
    }
  }

  .viewer-controls {
    display: flex;
    gap: 20rpx;
  }
}

.panorama-container {
  flex: 1;
  position: relative;
  background: #E0F2FE;
  overflow: hidden;

  .loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: #666;
    z-index: 10;
  }

  .panorama-canvas {
    width: 100%;
    height: 100%;
    transition: transform 0.3s;
  }

  .hotspot {
    position: absolute;
    width: 80rpx;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.8);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s;
    border: 4rpx solid white;
    z-index: 5;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);

    &.visited {
      background: #10B981;
      animation: bounce 0.5s;
    }

    &:hover {
      transform: scale(1.2);
      background: rgba(59, 130, 246, 1);
      box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
    }

    .hotspot-icon {
      font-size: 40rpx;
    }
  }

  .photo-controls {
    position: absolute;
    bottom: 60rpx;
    right: 60rpx;
    display: flex;
    flex-direction: column;
    gap: 20rpx;
    z-index: 10;

    .photo-btn {
      width: 120rpx;
      height: 120rpx;
      border-radius: 60rpx;
      background: #3B82F6;
      border: none;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
      transition: all 0.3s;

      &:hover {
        background: #2563EB;
        transform: scale(1.1);
      }

      .van-icon {
        font-size: 60rpx;
      }
    }

    .photo-count {
      background: rgba(0, 0, 0, 0.5);
      padding: 10rpx 20rpx;
      border-radius: 20rpx;
      color: white;
      font-size: 24rpx;
    }
  }

  .photo-preview {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 20;

    .preview-image {
      max-width: 80%;
      max-height: 60%;
      border-radius: 20rpx;
      box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.5);
    }

    .preview-actions {
      margin-top: 40rpx;
      display: flex;
      gap: 20rpx;
    }
  }

  .touch-hint {
    position: absolute;
    top: 40rpx;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.5);
    padding: 20rpx 40rpx;
    border-radius: 30rpx;
    color: white;
    font-size: 24rpx;
    z-index: 5;
  }
}

.hotspot-info {
  padding: 60rpx 40rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 20rpx 20rpx 0 0;

  .hotspot-title {
    display: block;
    font-size: 36rpx;
    color: #333;
    margin-bottom: 30rpx;
    font-weight: bold;
  }

  .hotspot-desc {
    display: block;
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
    margin-bottom: 60rpx;
  }

  .hotspot-actions {
    display: flex;
    justify-content: center;
    gap: 20rpx;
  }

  .van-button {
    flex: 1;
  }
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}
}