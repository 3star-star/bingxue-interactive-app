.favorites-container {
    min-height: 100vh;
    background: linear-gradient(135deg, #e0f7fa 0%, #b3e5fc 50%, #81d4fa 100%);
    font-family: 'Microsoft YaHei', sans-serif;
    padding-bottom: 80rpx;
}

.favorites-header {
    background: linear-gradient(135deg, #0277bd 0%, #01579b 100%);
    color: white;
    padding: 30rpx 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 750rpx;
    margin: 0 auto;
}

.back-button {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    padding: 15rpx 30rpx;
    border-radius: 30rpx;
    font-size: 28rpx;
    transition: background 0.3s ease;
}

.back-button:hover {
    background: rgba(255, 255, 255, 0.3);
}

.header-title {
    font-size: 36rpx;
    font-weight: bold;
}

.action-button {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    padding: 15rpx 30rpx;
    border-radius: 30rpx;
    font-size: 28rpx;
    transition: background 0.3s ease;
}

.action-button:hover {
    background: rgba(255, 255, 255, 0.3);
}

.favorites-main {
    max-width: 750rpx;
    margin: 30rpx auto;
    padding: 0 30rpx;
}

.category-tabs {
    display: flex;
    gap: 20rpx;
    margin-bottom: 30rpx;
    flex-wrap: wrap;
    justify-content: center;
}

.tab-button {
    background: white;
    border: none;
    padding: 20rpx 40rpx;
    border-radius: 30rpx;
    font-size: 28rpx;
    transition: all 0.3s ease;
    box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.tab-button:hover {
    transform: translateY(-5rpx);
    box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

.tab-button.active {
    background: #0277bd;
    color: white;
}

.favorites-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30rpx;
}

.favorite-item {
    background: white;
    border-radius: 20rpx;
    overflow: hidden;
    box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease;
}

.favorite-item:hover {
    transform: translateY(-10rpx);
}

.favorite-card {
    display: flex;
    flex-direction: column;
}

.favorite-image {
    height: 300rpx;
    overflow: hidden;
}

.favorite-image image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.favorite-item:hover .favorite-image image {
    transform: scale(1.05);
}

.favorite-info {
    padding: 30rpx;
    flex-grow: 1;
}

.favorite-title {
    color: #0277bd;
    font-size: 32rpx;
    margin-bottom: 15rpx;
    display: block;
    font-weight: bold;
}

.favorite-desc {
    color: #546e7a;
    font-size: 26rpx;
    margin-bottom: 20rpx;
    display: block;
}

.favorite-meta {
    display: flex;
    gap: 20rpx;
    margin-top: auto;
}

.meta-item {
    background: #e1f5fe;
    color: #0277bd;
    padding: 10rpx 20rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
}

.favorite-actions {
    display: flex;
    gap: 15rpx;
    padding: 20rpx;
    background: #f5f5f5;
    border-top: 1rpx solid #e0e0e0;
}

.action-button {
    flex: 1;
    padding: 15rpx;
    border: none;
    border-radius: 15rpx;
    font-size: 26rpx;
    transition: all 0.3s ease;
}

.view-button {
    background: #0277bd;
    color: white;
}

.view-button:hover {
    background: #01579b;
}

.delete-button {
    background: #f44336;
    color: white;
}

.delete-button:hover {
    background: #d32f2f;
}

.favorites-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: white;
    box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
    z-index: 100;
}

.bottom-nav {
    display: flex;
    justify-content: space-around;
    padding: 15rpx 0;
}

.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #666;
    font-size: 24rpx;
}

.nav-item.active {
    color: #0277bd;
}

.nav-icon {
    font-size: 40rpx;
    margin-bottom: 5rpx;
}

/* 响应式设计 */
@media (max-width: 768px) {
    .favorites-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .favorites-grid {
        grid-template-columns: 1fr;
    }
}