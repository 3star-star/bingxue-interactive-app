<!-- 滑雪姿势示意图 SVG -->
<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <g transform="translate(100,100)">
    <!-- 身体 -->
    <ellipse cx="0" cy="-30" rx="15" ry="40" fill="#4A90E2" transform="rotate(-20)"/>
    <!-- 头 -->
    <circle cx="-10" cy="-70" r="15" fill="#FDBCB4"/>
    <!-- 左臂 -->
    <line x1="-15" y1="-40" x2="-50" y2="-60" stroke="#FDBCB4" stroke-width="8" stroke-linecap="round"/>
    <!-- 右臂 -->
    <line x1="-5" y1="-35" x2="20" y2="-50" stroke="#FDBCB4" stroke-width="8" stroke-linecap="round"/>
    <!-- 左腿 -->
    <line x1="-10" y1="0" x2="-20" y2="40" stroke="#4A90E2" stroke-width="10" stroke-linecap="round"/>
    <!-- 右腿 -->
    <line x1="0" y1="0" x2="20" y2="40" stroke="#4A90E2" stroke-width="10" stroke-linecap="round"/>
    <!-- 雪板 -->
    <ellipse cx="-15" cy="50" rx="40" ry="8" fill="#8B4513" transform="rotate(-30)"/>
    <ellipse cx="15" cy="50" rx="40" ry="8" fill="#8B4513" transform="rotate(30)"/>
  </g>
</svg>